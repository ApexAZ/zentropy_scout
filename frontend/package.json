{
	"name": "frontend",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test --project=chromium",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:chromium": "playwright test --project=chromium",
		"test:e2e:firefox": "playwright test --project=firefox",
		"test:e2e:webkit": "playwright test --project=webkit",
		"test:e2e:all": "playwright test",
		"test:e2e:integration": "INTEGRATION=true playwright test --project=integration",
		"test:e2e:visual": "docker compose -f docker/docker-compose.playwright.yml run --rm playwright npx playwright test tests/e2e/visual-regression.spec.ts",
		"test:e2e:visual:update": "docker compose -f docker/docker-compose.playwright.yml run --rm playwright npx playwright test tests/e2e/visual-regression.spec.ts --update-snapshots"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@hookform/resolvers": "^5.2.2",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-table": "^8.21.3",
		"@tiptap/extension-link": "^3.20.0",
		"@tiptap/markdown": "^3.20.0",
		"@tiptap/pm": "^3.20.0",
		"@tiptap/react": "^3.20.0",
		"@tiptap/starter-kit": "^3.20.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"diff": "^8.0.3",
		"lucide-react": "^0.575.0",
		"next": "^16.2.3",
		"radix-ui": "^1.4.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hook-form": "^7.71.2",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"overrides": {
		"hono": ">=4.12.7"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^5.1.4",
		"@vitest/coverage-v8": "^4.0.18",
		"eslint": "^9.39.3",
		"eslint-config-next": "16.1.6",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"jsdom": "^28.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn": "^3.8.5",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.18"
	}
}
